# SNMP community used by snmp-collector (reuse Akvorado's existing community).
SNMP_COMMUNITY=changeme
# IPinfo token for the geoip updater (https://ipinfo.io/).
IPINFO_TOKEN=changeme
# Grafana admin password (grafana service reads GF_SECURITY_ADMIN_PASSWORD directly).
GF_SECURITY_ADMIN_PASSWORD=changeme
# Public URL Grafana is served on.
GF_SERVER_ROOT_URL=http://localhost:3000
# Telegram bot for the "container down" alert (contact point in
# docker/grafana/provisioning/alerting/contactpoints.yaml). Message @BotFather
# on Telegram, /newbot, copy the token. Then message your new bot once and hit
# https://api.telegram.org/bot<token>/getUpdates to read your chat id from the
# response ("chat":{"id": ...}).
TELEGRAM_BOT_TOKEN=changeme
TELEGRAM_CHAT_ID=changeme
