# ---- Compose ----
COMPOSE_PROJECT_NAME=akvorado

# ---- HyperDX / ClickStack images ----
HDX_IMAGE_REPO=docker.hyperdx.io
CH_IMAGE_REPO=docker.clickhouse.com
IMAGE_NAME_DOCKERHUB=hyperdx/hyperdx
NEXT_OTEL_COLLECTOR_IMAGE_NAME_DOCKERHUB=clickhouse/clickstack-otel-collector
OTEL_COLLECTOR_IMAGE_NAME_DOCKERHUB=hyperdx/hyperdx-otel-collector
CODE_VERSION=2.19.0
IMAGE_VERSION=2

# ---- HyperDX ports/URLs (app moved 8080 -> 1800) ----
HYPERDX_API_PORT=8000
HYPERDX_APP_PORT=1888
# Public URL HyperDX is served on (behind the Cloudflare-fronted reverse proxy).
# HYPERDX_FRONTEND_URL is the full external origin (frontend base + API CORS, no :port on 443).
HYPERDX_APP_URL=https://hyperdx.example.com
HYPERDX_FRONTEND_URL=https://hyperdx.example.com
HYPERDX_LOG_LEVEL=debug
HYPERDX_OPAMP_PORT=4320
HYPERDX_BASE_PATH=

# ---- Otel/ClickHouse ----
HYPERDX_OTEL_EXPORTER_CLICKHOUSE_DATABASE=default
